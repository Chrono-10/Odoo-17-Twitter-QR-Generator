<odoo>

    <!-- TREE VIEW -->
    <record id="view_twitter_account_tree" model="ir.ui.view">
        <field name="name">twitter.account.tree</field>
        <field name="model">twitter.account</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="twitter_handle" />
                <field name="twitter_url" />
                <field name="active" />
            </tree>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_twitter_account_form" model="ir.ui.view">
        <field name="name">twitter.account.form</field>
        <field name="model">twitter.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="twitter_handle" />
                        <field name="twitter_url" readonly="1" />
                        <field name="active" />
                        <field name="qr_code" widget="image" />
                    </group>
                    <button name="action_regenerate_qr"
                        type="object"
                        string="Regenerate QR"
                        class="btn-primary" />
                </sheet>
            </form>
        </field>
    </record>

    <!-- ✅ ACTION MUST COME BEFORE MENU -->
    <record id="twitter_account_action" model="ir.actions.act_window">
        <field name="name">Twitter Accounts</field>
        <field name="res_model">twitter.account</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- MENUS AFTER ACTION -->
    <menuitem id="twitter_qr_root" name="Twitter QR" />

    <menuitem id="twitter_qr_menu"
        name="Accounts"
        parent="twitter_qr_root"
        action="twitter_account_action" />

</odoo>